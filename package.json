{
  "name": "@tenex/salt",
  "version": "0.1.0",
  "description": "Tenex Salt React component library",
  "private": false,
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "bun@1.2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": ["dist", "src", "docs", "README.md"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {"types": "./dist/index.d.ts", "import": "./dist/index.js", "require": "./dist/index.cjs"},
    "./styles.css": "./dist/styles.css",
    "./styles/base.css": "./dist/base.css",
    "./styles/security.css": "./dist/security.css"
  },
  "sideEffects": ["**/*.css"],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean && bun run build:css",
    "build:css": "mkdir -p dist && cp src/styles/*.css dist/ && cat src/styles/base.css src/styles/security.css > dist/styles.css",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "check": "bun run typecheck && bun run test && bun run build && bun run build-storybook"
  },
  "peerDependencies": {
    "react": ">=18.3 <20",
    "react-dom": ">=18.3 <20"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.3.4",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "lucide-react": "^0.474.0",
    "react-day-picker": "^9.11.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.1.4",
    "@storybook/addon-docs": "^10.1.4",
    "@storybook/addon-themes": "^10.1.4",
    "@storybook/react-vite": "^10.1.4",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.0.0",
    "jsdom": "^26.0.0",
    "storybook": "^10.1.4",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vite": "^7.2.0",
    "vitest": "^3.0.0"
  }
}
