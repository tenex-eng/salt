{
  "name": "@tenex-eng/salt",
  "version": "0.5.0",
  "description": "Tenex design system and React component library",
  "private": false,
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "bun@1.2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "files": [
    "bin/install-salt-skill.mjs",
    "dist",
    "src",
    "docs",
    "skills",
    "README.md",
    "CHANGELOG.md",
    "AI.md",
    "llms.txt"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "salt-install-skill": "./bin/install-salt-skill.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./styles/base.css": "./dist/base.css",
    "./styles/tailwind.css": "./dist/tailwind.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean && bun run build:css",
    "build:css": "bun run scripts/build-css.mjs",
    "check:ai-docs": "bun run scripts/check-ai-docs.mjs",
    "check:package": "bun run scripts/check-package-contents.mjs",
    "check:css-contract": "bun run scripts/check-css-contract.mjs",
    "check:public-surface": "bun run scripts/check-public-surface.mjs",
    "check:runtime-deps": "bun run scripts/check-runtime-dependencies.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint src --ignore-pattern '**/*.stories.tsx' && eslint .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build && bun run check:public-surface && bun run check:css-contract && bun run check:runtime-deps && bun run build-storybook && bun run check:ai-docs && bun run check:package"
  },
  "peerDependencies": {
    "@tanstack/react-hotkeys": ">=0.1 <1",
    "date-fns": ">=4.1 <5",
    "next-themes": "^0.4.6",
    "react": ">=18.3 <20",
    "react-day-picker": "^9.11.3",
    "react-dom": ">=18.3 <20",
    "sonner": "^2.0.7"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.6",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.3.4",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "lucide-react": "^0.474.0",
    "react-resizable-panels": "2.1.7",
    "tailwind-merge": "^3.0.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@storybook/addon-a11y": "^10.1.4",
    "@storybook/addon-docs": "^10.1.4",
    "@storybook/addon-themes": "^10.1.4",
    "@storybook/react-vite": "^10.1.4",
    "@tailwindcss/postcss": "^4.1.0",
    "@tanstack/hotkeys": "^0.8.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "date-fns": "^4.3.0",
    "embla-carousel-react": "^8.6.0",
    "eslint": "^9.0.0",
    "eslint-plugin-oxlint": "^1.67.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "input-otp": "^1.4.2",
    "jsdom": "^26.0.0",
    "next-themes": "^0.4.6",
    "oxlint": "^1.67.0",
    "react-day-picker": "^9.11.3",
    "react-hook-form": "^7.76.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "storybook": "^10.1.4",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.60.0",
    "vaul": "^1.1.2",
    "vite": "^7.2.0",
    "vitest": "^3.0.0",
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "next-themes": {
      "optional": true
    }
  }
}
